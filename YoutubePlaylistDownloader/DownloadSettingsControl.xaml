<UserControl x:Class="YoutubePlaylistDownloader.DownloadSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             FlowDirection="{DynamicResource FlowDirection}"
             HorizontalAlignment="Center">

    <Grid Margin="30,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource General}" Style="{StaticResource SectionTitle}" />
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource SaveDirectory}" Margin="5" VerticalAlignment="Center" />
                            <TextBox x:Name="SaveDirectoryTextBox" Margin="5" TextChanged="SaveDirectoryTextBox_TextChanged" MouseDoubleClick="TextBox_MouseDoubleClick" HorizontalAlignment="Left" MinWidth="120" VerticalAlignment="Center" />
                            <Button Click="Tile_Click" HorizontalAlignment="Left" Margin="5,0,0,0" Padding="12,6" Background="{DynamicResource MahApps.Brushes.Accent}" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                <iconPacks:PackIconModern Width="16" Height="16" Kind="FolderOpen" />
                            </Button>
                        </StackPanel>
                        <CheckBox x:Name="UniquePlaylistDirectoryCheckBox" Content="{DynamicResource SavePlaylistInUniqueDirectory}" Margin="7" />
                        <CheckBox x:Name="OpenDestinationFolderCheckBox" Content="{DynamicResource OpenDestinationFolderOnFinish}" Margin="7" />
                        <CheckBox x:Name="DownloadThumbnailCheckBox" Content="{DynamicResource DownloadThumbnail}" Margin="7" />
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource FileNamePattern}" Margin="5" VerticalAlignment="Center" />
                            <TextBox x:Name="FileNamePattenTextBox" TextChanged="FileNamePattenTextBox_TextChanged" Margin="5" HorizontalAlignment="Left" MinWidth="120" VerticalAlignment="Center" />
                            <Button Click="RestPatternToDefault_Click" Content="{DynamicResource ResetToDefault}" HorizontalAlignment="Center" Margin="10,0,0,0" MinWidth="120" Padding="16,8" Background="{DynamicResource MahApps.Brushes.Accent}" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <CheckBox x:Name="SkipExistingCheckbox" Content="{DynamicResource SkipExisting}" Margin="7" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Video}" Style="{StaticResource SectionTitle}" />
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{DynamicResource SaveVideoFormat}" Margin="5"  />
                            <ComboBox HorizontalContentAlignment="Left" HorizontalAlignment="Center" VerticalContentAlignment="Center" Width="Auto" x:Name="SaveVideosFormatDropDown" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" >
                            <CheckBox Content="{DynamicResource Prefer}" Margin="7" x:Name="PreferCheckBox" HorizontalAlignment="Center" IsChecked="False"  />
                            <ComboBox HorizontalContentAlignment="Left" HorizontalAlignment="Center" VerticalContentAlignment="Center" Width="Auto" x:Name="ResulotionDropDown" VerticalAlignment="Center"/>
                        </StackPanel>
                        <CheckBox Margin="7" x:Name="PreferHighestFPSCheckBox" Content="{DynamicResource PreferFPS}" />
                        <CheckBox x:Name="CaptionsCheckBox" Margin="7" Content="{DynamicResource DownloadCaptions}" />
                        <WrapPanel>
                            <Label Content="{DynamicResource CaptionsLanguage}" Margin="7" VerticalAlignment="Center" />
                            <ComboBox Height="10" x:Name="CaptionsLanguagesComboBox" Width="Auto" />
                        </WrapPanel>
                        <WrapPanel>
                            <Label Content="{DynamicResource VideoLanguage}" Margin="7" VerticalAlignment="Center" />
                            <ComboBox Height="10" x:Name="VideoLanguagesComboBox" Width="Auto" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Audio}" Style="{StaticResource SectionTitle}" />
                        <StackPanel Orientation="Horizontal" >
                            <CheckBox Content="{DynamicResource ConvertToMp3}" Margin="7" x:Name="ConvertCheckBox" HorizontalAlignment="Center" IsChecked="False" />
                            <ComboBox HorizontalContentAlignment="Left" HorizontalAlignment="Center" VerticalContentAlignment="Center" Width="Auto" x:Name="ExtensionsDropDown" VerticalAlignment="Center"/>
                            <CheckBox Content="{DynamicResource BitRate}" Margin="7" x:Name="BitrateCheckBox" />
                            <TextBox  Margin="0,7" x:Name="BitRateTextBox" TextAlignment="Center" MinWidth="40" Width="Auto" />
                            <Label Content="kbps" Margin="7" />
                        </StackPanel>
                        <CheckBox Margin="7" x:Name="TagAudioFileCheckBox" Content="{DynamicResource TagAudioFile}" />
                        <CheckBox Margin="7" x:Name="AudioOnlyCheckBox" Content="{DynamicResource AudioOnly}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Playlist}" Style="{StaticResource SectionTitle}" />
                        <CheckBox Content="{DynamicResource NumberVideosByPlaylistIndex}" Margin="7" x:Name="NumberVideosByPlaylistIndexCheckBox" />
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="{DynamicResource PlaylistIndex}" Margin="7" x:Name="PlaylistIndexCheckBox" VerticalAlignment="Center"/>
                            <TextBox Width="50" x:Name="PlaylistStartIndexTextBox" Text="1" Margin="5,7" TextAlignment="Center" VerticalAlignment="Center"/>
                            <Label Content="{DynamicResource UntilIndex}" Margin="7" VerticalAlignment="Center"/>
                            <TextBox Width="50" x:Name="PlaylistEndIndexTextBox" Text="" Margin="5,7" TextAlignment="Center" VerticalAlignment="Center"/>
                            <Label Content="{DynamicResource LeaveEmptyOrZeroForUntilTheEnd}" Margin="7" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Filter}" Style="{StaticResource SectionTitle}" />
                        <StackPanel Orientation="Horizontal" >
                            <CheckBox Content="{DynamicResource DownloadFilter}" Margin="7" x:Name="FilterByLengthCheckBox" HorizontalAlignment="Center" IsChecked="False" />
                            <ComboBox HorizontalContentAlignment="Left" HorizontalAlignment="Center" VerticalContentAlignment="Center" Width="Auto" x:Name="FilterByLengthShorterOrLongerDropDown" VerticalAlignment="Center"/>
                            <Label Content="{DynamicResource Than}" Margin="7" />
                            <TextBox  Margin="0,7" x:Name="FilterByLengthTextBox" TextAlignment="Center" MinWidth="40" Width="Auto" />
                            <Label Content="{DynamicResource Minutes}" Margin="7" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
