<UserControl x:Class="YoutubePlaylistDownloader.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             Margin="10"
             FlowDirection="{DynamicResource FlowDirection}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>


        <Controls:MetroAnimatedTabControl Grid.Row="1" x:Name="MetroAnimatedTabControl">
            <Controls:MetroTabItem Header="{DynamicResource Search}">
                <Grid x:Name="SearchPlaylistGrid" >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" x:Name="HeadlineStackPanel" HorizontalAlignment="Stretch" Margin="5,5,5,15" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Controls:Tile Grid.Column="0" Click="Tile_Click" Style="{StaticResource RoundAccentIconButton}" Margin="0,0,12,0" ToolTip="{DynamicResource Options}" VerticalAlignment="Center">
                            <iconPacks:PackIconModern Kind="Cog" Width="20" Height="20" />
                        </Controls:Tile>
                        <TextBox Grid.Column="1" HorizontalAlignment="Stretch"  x:Name="PlaylistLinkTextBox" Margin="0,5" FontSize="18" TextChanged="TextBox_TextChanged" Style="{StaticResource SeachBarPlaceHolder}" Tag="{DynamicResource InsertYoutubePlaylistLinkHere}"  />
                    </Grid>
                    <ScrollViewer Grid.Row="1" x:Name="GridScrollViewer" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Visibility="Collapsed" x:Name="PlaylistInfoGrid" Margin="7,10,7,20" 
                                    Style="{StaticResource SectionCard}" HorizontalAlignment="Stretch" Width="Auto">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto" MinWidth="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Col 0: Thumbnail with rounded corners -->
                                    <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="4" Margin="0,0,24,0" MaxWidth="320" MaxHeight="180">
                                        <Grid.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black" />
                                        </Grid.Effect>
                                        <Border CornerRadius="8" ClipToBounds="True">
                                            <Image x:Name="PlaylistInfoImage" Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>

                                    <!-- Col 1 Labels: bold and clean -->
                                    <TextBlock Text="{DynamicResource PlaylistTitle}" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Margin="0,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                    <TextBlock Text="{DynamicResource Author}"        Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Margin="0,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                    <TextBlock Text="{DynamicResource Views}"         Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Margin="0,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                    <TextBlock Text="{DynamicResource TotalVideos}"   Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Margin="0,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" x:Name="PlaylistTotalVideosTextBlockText" />

                                    <!-- Col 2 Values -->
                                    <TextBlock x:Name="PlaylistTitleTextBlock"        Grid.Row="0" Grid.Column="2" FontSize="14" Margin="10,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="PlaylistAuthorTextBlock"       Grid.Row="1" Grid.Column="2" FontSize="14" Margin="10,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="PlaylistViewsTextBlock"        Grid.Row="2" Grid.Column="2" FontSize="14" Margin="10,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="PlaylistTotalVideosTextBlock"  Grid.Row="3" Grid.Column="2" FontSize="14" Margin="10,5" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="VideosDataGrid" Visibility="Collapsed"
                                      AutoGenerateColumns="False" IsReadOnly="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      CanUserReorderColumns="False" CanUserSortColumns="True"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      HorizontalAlignment="Stretch"
                                      MaxHeight="350" Margin="7,5"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="40">
                                        <DataGridTemplateColumn.Header>
                                            <CheckBox x:Name="SelectAllCheckBox" IsChecked="True"
                                                      Checked="SelectAllCheckBox_Changed" Unchecked="SelectAllCheckBox_Changed" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                          HorizontalAlignment="Center"
                                                          Checked="VideoCheckBox_Changed" Unchecked="VideoCheckBox_Changed" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" IsReadOnly="True" />
                                    <DataGridTextColumn Binding="{Binding Title}" Width="*" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource PlaylistTitle}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Duration}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource Duration}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Channel}" Width="180" IsReadOnly="True">
                                        <DataGridTextColumn.Header>
                                            <TextBlock Text="{DynamicResource Channel}" />
                                        </DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="110">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource Quality}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedValue="{Binding SelectedVideoQuality, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                          SelectedValuePath="Tag" MinWidth="90" Margin="2"
                                                          x:Name="QualityCombo">
                                                    <ComboBoxItem Tag="" Content="{DynamicResource Global}" />
                                                    <ComboBoxItem Tag="144p" Content="144p" />
                                                    <ComboBoxItem Tag="240p" Content="240p" />
                                                    <ComboBoxItem Tag="360p" Content="360p" />
                                                    <ComboBoxItem Tag="480p" Content="480p" />
                                                    <ComboBoxItem Tag="720p" Content="720p" />
                                                    <ComboBoxItem Tag="1080p" Content="1080p" />
                                                    <ComboBoxItem Tag="1440p" Content="1440p" />
                                                    <ComboBoxItem Tag="2160p" Content="2160p (4K)" />
                                                    <ComboBoxItem Tag="2880p" Content="2880p" />
                                                    <ComboBoxItem Tag="3072p" Content="3072p" />
                                                    <ComboBoxItem Tag="4320p" Content="4320p (8K)" />
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="100">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="{DynamicResource AudioBitrate}" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedValue="{Binding SelectedAudioBitrate, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                          SelectedValuePath="Tag" MinWidth="80" Margin="2"
                                                          x:Name="BitrateCombo">
                                                    <ComboBoxItem Tag="" Content="{DynamicResource Global}" />
                                                    <ComboBoxItem Tag="128" Content="128 kbps" />
                                                    <ComboBoxItem Tag="192" Content="192 kbps" />
                                                    <ComboBoxItem Tag="256" Content="256 kbps" />
                                                    <ComboBoxItem Tag="320" Content="320 kbps" />
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2" x:Name="SelectionCountTextBlock" Visibility="Collapsed"
                                       HorizontalAlignment="Center" Margin="0,5,0,10" FontSize="14" FontWeight="Medium" />

                            <WrapPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,15,0,10">
                                <Controls:Tile Style="{DynamicResource SmallTileStyle}" x:Name="DownloadButton" Title="{DynamicResource Download}" IsEnabled="False" MinWidth="200" Width="Auto" HorizontalTitleAlignment="Center" Click="DownloadButton_Click">
                                    <iconPacks:PackIconModern Width="40" Height="40" Kind="ArrowDown" />
                                </Controls:Tile>
                                <Controls:Tile Style="{DynamicResource SmallTileStyle}" x:Name="DownloadInBackgroundButton" Title="{DynamicResource DownloadInBackground}" MinWidth="200" Width="Auto" HorizontalTitleAlignment="Center" IsEnabled="False" Click="DownloadInBackgroundButton_Click">
                                    <iconPacks:PackIconModern Width="40" Height="40" Kind="Reset" />
                                </Controls:Tile>
                                <Controls:Tile Style="{DynamicResource SmallTileStyle}" x:Name="SavePlaylistInfoButton" Title="{DynamicResource SavePlaylistInfo}" MinWidth="200" Width="Auto" HorizontalTitleAlignment="Center" IsEnabled="False" Click="SavePlaylistInfoButton_Click">
                                    <iconPacks:PackIconModern Width="40" Height="40" Kind="Save" />
                                </Controls:Tile>
                            </WrapPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>

            </Controls:MetroTabItem>
            <Controls:MetroTabItem Header="{DynamicResource Queue}" x:Name="QueueMetroTabItem">
                <Grid>
                    <ScrollViewer x:Name="QueueScrollViewer" VerticalScrollBarVisibility="Auto" >
                        <StackPanel x:Name="QueueStackPanel">
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Controls:MetroTabItem>

            <Controls:MetroTabItem Header="{DynamicResource BulkDownload}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" x:Name="BulkScrollViewer" VerticalScrollBarVisibility="Auto" >
                        <TextBox x:Name="BulkLinksTextBox" AcceptsReturn="True" TextWrapping="Wrap" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" TextChanged="TextBox_TextChanged_1" FontSize="16" PreviewDrop="BulkLinksTextBox_PreviewDrop"  />
                    </ScrollViewer>
                    <WrapPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,15,0,10">
                        <Controls:Tile Style="{DynamicResource SmallTileStyle}" x:Name="BulkDownloadButton" Title="{DynamicResource Download}" MinWidth="200" Width="Auto" HorizontalTitleAlignment="Center" IsEnabled="False" Click="BulkDownloadButton_Click">
                            <iconPacks:PackIconModern Width="40" Height="40" Kind="ArrowDown" />
                        </Controls:Tile>
                    </WrapPanel>
                </Grid>
            </Controls:MetroTabItem>

        </Controls:MetroAnimatedTabControl>
    </Grid>
</UserControl>
