<Window x:Class="YoutubePlaylistDownloader.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Mini Player" Height="100" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseDoubleClick="Window_MouseDoubleClick">
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#333333" BorderThickness="1" 
            Padding="10" Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.6" ShadowDepth="2" Direction="270" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Width="110" Height="62" CornerRadius="8" Background="#2D2D2D" ClipToBounds="True" Margin="0,0,10,0">
                <Image x:Name="ThumbnailImage" Stretch="UniformToFill" />
            </Border>
            
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="TitleText" Text="Idle" FontSize="13" FontWeight="SemiBold" Foreground="White" 
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Top" MaxHeight="40" TextWrapping="Wrap"/>
                
                <TextBlock x:Name="StatusText" Text="Waiting for downloads..." FontSize="11" Foreground="#AAAAAA" 
                           Grid.Row="1" Margin="0,4,0,4" TextTrimming="CharacterEllipsis"/>
                
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Controls:MetroProgressBar x:Name="ProgressBar" Height="4" Margin="0,0,8,0" 
                                             Foreground="#FF3366" Background="#333333" Minimum="0" Maximum="100" />
                    <TextBlock x:Name="SpeedText" Text="" FontSize="10" Foreground="#888888" Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
